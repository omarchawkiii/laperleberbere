Options -Indexes
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
    RewriteEngine On
</IfModule>

# Sécurité : bloquer l'accès direct aux fichiers de config
<FilesMatch "^(db|mail)\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Encodage
AddDefaultCharset UTF-8

# PHP (cPanel/CGI)
<IfModule mod_suphp.c>
    suPHP_ConfigPath /home/omodiz
</IfModule>
